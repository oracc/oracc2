#include <oraccsys.h>
#include <roco.h>
#include <form.h>

static Roco *r;
static Hash *stems;

void
normify_init(Pool *p)
{
  stems = hash_create(128);
  r = roco_load1("@@ORACC@@/epsd2/02pub/stems.tsv");
  int i;
  for (i = 0; i < r->nlines; ++i)
    {
      hash_add(stems, r->rows[i][1], r->rows[i][3]);
      unsigned char *cgpb = pool_alloc(strlen((ccp)r->rows[i][0])
				       +strlen((ccp)r->rows[i][1])+2, p);
      sprintf((char*)cgpb, "%s%c%s", r->rows[i][0], 0x01, r->rows[i][1]);
      hash_add(stems, cgpb, r->rows[i]);
    }
}

void
normify_term(void)
{
  roco_destroy(r);
  hash_free(stems, NULL);
}

char *
normify(const char *cgpb, const char *c, const char *b, const char *m, char **stem)
{
  const char *s = c;
  if (/*'V' == *e && */strchr(b, '-'))
    {
      const char **r = hash_find(stems, (unsigned const char *)cgpb);
      if (r)
	{
	  s = r[3];
	  if (stem)
	    *stem = (char*)r[2];
	}
    }
  char ret[1024];
  const char *tilde = strchr(m, '~');
  if (tilde)
    {
      if (tilde > m)
	{
	  int len = tilde-m;
	  strncpy(ret, m, len);
	  ret[len] = '\0';
	}
      else
	*ret = '\0';
      strcat(ret, s);
      strcat(ret, tilde+1);
    }
  else
    strcpy(ret, c);
  return strdup(ret);
}

/* Only normify forms if they have base/morph */
void
normify_form(Form *f, Pool *p)
{
  if (f->base && f->morph)
    {
      char *stem = NULL;
      char cgpb[strlen((ccp)f->cf)+strlen((ccp)f->gw)+strlen((ccp)f->pos)+strlen((ccp)f->base)+strlen("[]0")];
      sprintf(cgpb, "%s[%s]%s%c%s", f->cf, f->gw, f->pos, 0x01, f->base);
      char *n = normify(cgpb, (ccp)f->cf, (ccp)f->base, (ccp)f->morph, &stem);
      f->norm = pool_copy((uccp)n, p);
      if (!f->stem || '\0' == *f->stem)
	{
	  if (stem)
	    f->stem = (uccp)stem;
	  else
	    f->stem = (uccp)"B";
	}
      free(n);
    }
}
