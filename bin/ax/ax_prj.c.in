#include <stdlib.h>
#include <stdio.h>
#include <string.h>
#include <xpd.h>
#include "ax.h"

extern int saa_mode;

void
proj_default(struct run_context *r)
{
  proj_init(r, "oracc");
}

void
proj_init(struct run_context *runp, const char *project)
{
  struct proj_context *p = hash_find(runp->known_projects, (unsigned char *)project);
  if (!p)
    {
      const char *o = NULL;
      p = calloc(1,sizeof(struct proj_context));
      p->name = (char *)pool_copy((unsigned char *)project, runp->pool);
      hash_add(runp->known_projects,
	       pool_copy((unsigned char *)project,runp->pool),
	       p);
      p->xpd = xpd_init(project,runp->pool);
      p->owner = runp;
      if (xpd_option(p->xpd,"atf-saa-mode"))
	saa_mode = xpd_option_int(p->xpd,"atf-saa-mode");
      o = xpd_option(p->xpd,"render-serial");
      if (o && !strcmp(o, "yes"))
	odt_serial = 1;
      /*set_project(p, project);*/
    }
  runp->proj = p;
}

void
proj_term(struct proj_context *proj)
{
  xpd_term(proj->xpd);
  free(proj);
}
