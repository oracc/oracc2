#!/bin/dash
#
# Ensure oracc/{bld,pub,tmp,xml,www}/$project exist and (re)set 01*
# and 02* links to them.
#
# This script is run by odo after the CVS refresh but before any other
# activity.
#
# It completely removes all of the computed data in 01* and 02* so it
# should only be done by odo itself when invoked with a build command
# that matches the project type.
#
#set -x
. ${ORACC}/bin/odo-func.sh
odo_odo $0 $*

# default to no-write-others
umask 002

project=$odo_proj
V=$odo_verb

if [ "$project" = "" ]; then
    echo $0: no project given. Stop.
    exit 1
fi

#echo $0: pwd = `pwd`

if [ ! -r 00lib/config.xml ]; then
    echo $0: no 00lib/config.xml for project $project. Stop.
    exit 1
fi

confproj=`proj-from-conf.sh`
if [ "$confproj" != "$project" ]; then
    echo $0: config.xml@n $confproj does not match given project $project. Stop.
    exit 1
fi

odov odo-reset emptying all '01*' and '02*' directories.

if [ "$ORACC_MODE" = "single" ]; then
    owner=`whoami`
    group="staff"
else
    owner=oradmin
    group=oradmin
fi

cd @@ORACC_BUILDS@@/$project
rm -fr .odo.d
mkdir .odo.d
for dir in bld pub tmp xml www ; do
    md=@@ORACC_BUILDS@@/$dir/$project
    rsync -a --delete .odo.d/ $md/
    chown $owner:$group $md
    chmod 2775 $md
done

mkdir -p 01log
rm $V -f 01bld 01tmp 02pub 02www 02xml
ln $V -sf @@ORACC_BUILDS@@/bld/$project 01bld
ln $V -sf @@ORACC_BUILDS@@/pub/$project 02pub
ln $V -sf @@ORACC_BUILDS@@/tmp/$project 01tmp
ln $V -sf @@ORACC_BUILDS@@/www/$project 02www
ln $V -sf @@ORACC_BUILDS@@/xml/$project 02xml
