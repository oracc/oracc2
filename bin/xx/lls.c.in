#include <oraccsys.h>
#include <roco.h>
#include <pool.h>
#include <hash.h>
#include <xml.h>
#include <runexpat.h>

/*lls: extract lemmatization but use sense GWs instead of the actual
  insts */

int verbose = 0;

int nlines;
int nmorph;
int xcl_mode;
FILE *outf;
Hash *idmap;
Hash *sgw;
Pool *p;

const char *curr_lem;

static void
load_sgw(void)
{
  sgw = hash_create(128);
  Roco *r = roco_load1("@@ORACC@@/epsd2/02pub/sgw.tsv");
  int i;
  for (i = 1; i < r->nlines; ++i)
    {
      char epos[strlen((ccp)r->rows[i][2])+2];
      if (*(ccp)r->rows[i][2] != '-')
	sprintf(epos, "'%s", (ccp)r->rows[i][2]);
      else
	*epos = '\0';

      char cgpsgw[strlen((ccp)r->rows[i][0])+strlen((ccp)r->rows[i][3])+strlen((ccp)r->rows[i][2])+strlen("'//0")];
      sprintf(cgpsgw, "%s//%s%s", (ccp)r->rows[i][0], (ccp)r->rows[i][3], epos);

      char inst[strlen((ccp)r->rows[i][0])+strlen(epos)+strlen((ccp)r->rows[i][1])+2];
      strcpy(inst, (ccp)r->rows[i][0]);
      char *sqb = strchr(inst, '[');
      if (sqb)
	{
	  ++sqb;
	  strcpy(sqb, (ccp)r->rows[i][1]);
	  strcat(sqb, "]");
	  strcat(sqb, epos);	  
	}
      if (verbose)
	fprintf(stderr, "hashing %s => %s\n", cgpsgw, inst);
      hash_add(sgw, (uccp)pool_copy((uccp)cgpsgw, p), (ucp)pool_copy((uccp)inst, p));
    }
}

void
relem(const char **atts)
{
  if (nmorph++)
    fputs("; ", outf);
  const char *m = findAttr(atts, "morph");
  const char *c = findAttr(atts, "cf");
  const char *p = findAttr(atts, "pos");
  if (*m)
    {
      const char *g = findAttr(atts, "gw");
      const char *s = findAttr(atts, "sense");
      const char *e = findAttr(atts, "epos");
      char key[strlen(c)+strlen(g)+strlen(p)+strlen(s)+strlen(e)+strlen("[]//'0")];
      sprintf(key, "%s[%s]%s//%s", c, g, p, s);
      if (verbose)
	fprintf(stderr, "trying %s\n", key);
      char *sg = hash_find(sgw, (uccp)key);
      if (!sg)
	{
	  strcat(key, "'");
	  strcat(key, e);
	  if (verbose)
	    fprintf(stderr, "trying %s\n", key);
	  sg = hash_find(sgw, (uccp)key);
	}
      if (sg)
	{
	  fputs(sg, outf);
	}
      else
	{
	  if (strlen(p) != 2 || 'N' != p[1])
	    fprintf(stderr, "%s: no sgw found\n", key);
	  fprintf(outf, "%s[%s]", c, s);
	}
      return;
    }
  else if (*c)
    fputs(c, outf);
  else if (*p)    
    fputs(p, outf);
  else
    fprintf(stderr, "lm1: %s has nothing to output\n", curr_lem);
  fputs(c, outf);
}

void
ei_sH(void *userData, const char *name, const char **atts)
{
  if (!strcmp(name, "xcl"))
    xcl_mode = 1;
  else if (!strcmp(name, "l"))
    {
      /* use of @n assumes #lm1: context will be inherited from ATF */
      if (!xcl_mode)
	hash_add(idmap,
		 pool_copy((unsigned const char *)findAttr(atts, "xml:id"), p),
		 pool_copy((unsigned const char *)findAttr(atts, "n"), p));
      else
	curr_lem = findAttr(atts, "xml:id");
    }
  else if (!strcmp(name, "xff:f"))
    relem(atts);
  else if (!strcmp(name, "d"))
    {
      const char *type = findAttr(atts, "type");
      if (!strcmp(type, "line-start"))
	{
	  if (nlines++)
	    fputs("\n", outf);
	  const char *lid = findAttr(atts, "ref");	  
	  fprintf(outf, "%s.\t", (const char*)hash_find(idmap, (unsigned const char *)lid));
	  nmorph = 0;
	}
    }
}

void
ei_eH(void *userData, const char *name)
{
}

void
expat_identity(const char *fname, const char *xml_id, FILE *outfp)
{
  char const *fnlist[2];
  fnlist[0] = fname;
  fnlist[1] = NULL;
  runexpatNSuD(i_list, fnlist, ei_sH, ei_eH, NULL, outfp);
}

int
main(int argc, char **argv)
{
  p = pool_init();
  load_sgw();
  options(argc, argv, "");
  runexpat_omit_rp_wrap();
  idmap = hash_create(256);
  outf = stdout;
  expat_identity(argv[optind], NULL, stdout);
  if (nlines++)
    fputs("\n", outf);
}

int
opts(int argc, const char *arg)
{
  switch (argc)
    {
    default: return 1;
    }
  return 0;
}
void help(void) {}
