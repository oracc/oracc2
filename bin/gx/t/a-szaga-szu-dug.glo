@sense N weft
@sense N content
@equiv %akk libbu
@end entry

@entry šu [hand] N
@bases sum₅; {kuš}šu; {tug₂}šu; {ŋeš}šu; šu; šu-be-a-am₆; šu-x; šu{+šu} (šu-šu); šu{kug-babbar}; šu{kug-sig₁₇}; šu{zabar}; šu₁₂ (šud₃); šu₂ (šuš₂)
